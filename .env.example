# ===== vietqr-pay (khuyáº¿n nghá»‹) =====
# Cháº¡y: cd C:\Users\Admin\vietqr-pay && npm start
VIETQR_PAY_URL=http://127.0.0.1:3000
PAYMENT_WEBHOOK_ENABLED=true
PAYMENT_WEBHOOK_HOST=127.0.0.1
PAYMENT_WEBHOOK_PORT=8787
# TrÃ¹ng JARVIS_FULFILL_SECRET trong vietqr-pay/.env
PAYMENT_WEBHOOK_SECRET=jarvis-local-webhook-secret-change-me

# License khi bÃ¡n SOURCE (tuá»³ chá»n)
REQUIRE_SOFTWARE_LICENSE=false
LICENSE_SECRET=
SOFTWARE_LICENSE_KEY=

# ===== AI provider =====
# groq (free) | openrouter | xai | nvidia | ollama
AI_PROVIDER=groq
AI_API_KEY=
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# NVIDIA NIM (https://build.nvidia.com) — model deepseek-ai/deepseek-v4-pro
# NVIDIA_API_KEY=nvapi-...
#
# Model theo goi (khuyen nghi):
# Trial/free → Groq | Basic/Pro/Business → GPT (NVIDIA)
PLAN_ROUTE_ENABLED=true
FREE_AI_PROVIDER=groq
FREE_AI_MODEL=llama-3.3-70b-versatile
PAID_AI_PROVIDER=nvidia
BASIC_AI_PROVIDER=nvidia
BASIC_AI_MODEL=openai/gpt-oss-120b
PAID_AI_MODEL=deepseek-ai/deepseek-v4-pro

# App
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./cache/jarvis.db
WORKSPACE_DIR=./workspace
MAX_HISTORY_MESSAGES=40

# ===== Web chat (python -m webapp.server) =====
WEB_HOST=0.0.0.0
WEB_PORT=7860
